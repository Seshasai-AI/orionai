# ============================================================
#  OrionAI — Environment Variables
#  Copy this file to .env for local development.
#  On Render: set these in Dashboard → Environment tab.
#  NEVER commit .env to GitHub.
# ============================================================

# Required — get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Required for web search — get free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — change the AI model
AI_MODEL=llama-3.3-70b-versatile

# Optional — max tokens in response
MAX_TOKENS=1024
